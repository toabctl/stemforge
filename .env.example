# Spotify OAuth credentials
# Register your app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# Pin to a specific device (partial name match, case-insensitive)
# Leave empty to auto-select the active device
SPOTIFY_DEVICE_NAME=

# Audio capture
# Use @DEFAULT_MONITOR@ to auto-detect, or set explicitly:
# e.g. alsa_output.pci-0000_07_00.6.analog-stereo.monitor
PULSE_MONITOR_SOURCE=@DEFAULT_MONITOR@
CAPTURE_DURATION_SECONDS=30
CAPTURE_SAMPLE_RATE=44100
CAPTURE_CHANNELS=2

# Stem separation
DEMUCS_MODEL=htdemucs_ft
DEMUCS_DEVICE=cpu
DEMUCS_SHIFTS=1

# Pipeline
PLAYBACK_START_DELAY_SECONDS=3.0
OUTPUT_DIR=output
