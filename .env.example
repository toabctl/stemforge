# Spotify OAuth credentials
# Register your app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# Pin to a specific device (partial name match, case-insensitive)
# SPOTIFY_DEVICE_NAME=

# Audio capture (PipeWire)
# Set to a specific PipeWire node name, or leave empty to auto-detect Spotify
# PIPEWIRE_SINK=
# CAPTURE_DURATION_SECONDS=60
# CAPTURE_SAMPLE_RATE=44100
# CAPTURE_CHANNELS=2

# Stem separation
# DEMUCS_MODEL=htdemucs_6s
# DEMUCS_DEVICE=cpu
# DEMUCS_SHIFTS=2

# MIDI conversion
# MIDI_ONSET_THRESHOLD=0.5
# MIDI_FRAME_THRESHOLD=0.3
# MIDI_MIN_NOTE_LENGTH=127.7

# Pipeline
# PLAYBACK_START_DELAY_SECONDS=3.0
# OUTPUT_DIR=output
